extends ../layouts/layout.pug

block content
	h2 Класс .grid-12 - создает сетку 479px  и 1fr
	section.work-area
		.container.gap-40
			.work-area-content.grid-12
				.work-area-col
					h2.h2.visible-desktop Работаем в&nbsp;Саратове и&nbsp;СО
					ul.work-area-list.medi-20
						li
							a.primary-link(href="#!") Саратов
						li
							a.primary-link(href="#!") Энгельс
						li
							a.primary-link(href="#!") Балаково
						li
							a.primary-link(href="#!") Балашов
						li
							a.primary-link(href="#!") Вольск
						li
							a.primary-link(href="#!") Пугачёв
						li
							a.primary-link(href="#!") Ртищево
						li
							a.primary-link(href="#!") Петровск
						li
							a.primary-link(href="#!") Маркс
						li
							a.primary-link(href="#!") Аткарск
						li
							a.primary-link(href="#!") Красноармейск
						li
							a.primary-link(href="#!") Ершов
					button.btn-primary
						span Посмотреть все города
						svg.svg-right
							use(href='./img/sprite.svg#svg-right')
				.work-area-map
					h2.h2.hide-desktop Работаем в&nbsp;Саратове и&nbsp;СО
					img(src='./img/map.webp'  width='987' height='549' loading='lazy' alt='img')
block variables
	-var title = "Показатели компании";