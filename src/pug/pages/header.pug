extends ../layouts/layout.pug

block content
	header.header
		//HEADER BOTTOM
		.header-bottom
			.container
				.logo-box
					a(href="#!").logo
						img(src='./img/logo.webp', srcset='./img/logo@2x.webp 2x' width='214' height='52' loading='lazy' alt='img')
				
				// HEADER DESKTOP MENU
				.header-menu-wrapper
					.header-menu
						ul.menu-list
							li.menu-item.has-submenu
								.menu-link
									a(href='#!') Благоустройство
									svg.svg-carret-down
										use(href='./img/sprite.svg#svg-carret-down')
								.menu-submenu-wrapper
									ul.menu-submenu.js-drop(data-mode='single')
										li.submenu-item.js-drop-item
											span.submenu-link.js-drop-button Услуги по благоустройству
												svg.svg-carret-down
													use(href='./img/sprite.svg#svg-carret-down')
											.js-drop-body
												ul.menu-sub-submenu.js-drop-content
													li.sub-submenu-item
														a(href='#!') Асвальтирование
													li.sub-submenu-item
														a(href='#!') Укладка тротуарной плитки
													li.sub-submenu-item
														a(href='#!') Озеленение
										
										
							li.menu-item.has-submenu
								.menu-link
									a(href='#!') Аренда спецтехники
									svg.svg-carret-down
										use(href='./img/sprite.svg#svg-carret-down')
								
								.menu-submenu-wrapper
									ul.menu-submenu
										li.submenu-item
											a.submenu-link(href='#!') Аренда бульдозера
										li.submenu-item
											a.submenu-link(href='#!') Аренда мини- погрузчика
										li.submenu-item
											a.submenu-link(href='#!') Аренда катка
							
							li.menu-item.has-submenu
								.menu-link
									a(href='#!') Бетонные полы
									svg.menu-item-icon
										use(href='./img/sprite.svg#svg-carret-down')
								.menu-submenu-wrapper
									ul.menu-submenu
										li.submenu-item
											a.submenu-link(href='#!') Бетонные полы
										
							
							li.menu-item
								.menu-link
									a(href='#!') Объекты
										
							li.menu-item
								.menu-link
									a(href='#!') Контакты
				
				//RIGHT COLUMN
				.header-bottom-right
					button.open-search.btn-square
						svg.svg-search
							use(href='./img/sprite.svg#svg-search')

					.social-block
						a(href="#!").social-item
							svg.svg-whatsapp
								use(href='./img/social-icons.svg#svg-whatsapp')
						
						a(href="#!").social-item
							svg.svg-max
								use(href='./img/social-icons.svg#svg-max')
						
						a(href="#!").social-item
							svg.svg-telegram
								use(href='./img/social-icons.svg#svg-telegram')



block variables
	-var title = "HEADER";
