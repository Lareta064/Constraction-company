						button.btn-primary(type="button"  disabled)
							span Текст на кнопке
							svg.svg-email
								use(href='../img/sprite.svg#svg-email')
					
					p.dashed
					button.btn-primary(type="button")
						span Текст на кнопке
						svg.svg-round-check
							use(href='../img/sprite.svg#svg-round-check')
					pre.
					button.btn-primary(type="button")
						span Текст на кнопке
						svg.svg-round-check
							use(href='./img/sprite.svg#svg-round-check')
					
					p.dashed
					button.btn-outline(type="button") Текст на кнопке
					pre.
						button.btn-outline(type="button") Текст на кнопке