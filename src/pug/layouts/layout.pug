include _mixins-links.pug
block variables

doctype html
html(lang="ru")
	head
		meta(charset="UTF-8")
		
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		meta(http-equiv="X-UA-Compatible", content="ie=edge")
		//=======убрать перевод цифр в номер телефона на ios  и safari ======
		meta(name="format-detection" content="telephone=no")

		title !{title}
		style.
			@font-face {
				font-family: 'Montserrat';
				src: url('./fonts/Montserrat-Regular.woff2') format('woff2');
				font-weight: 400;
				font-style: normal;
			}
			@font-face {
				font-family: 'Montserrat';
				src: url('./fonts/Montserrat-Medium.woff2') format('woff2');
				font-weight: 500;
				font-style: normal;
			}
			@font-face {
				font-family: 'Montserrat';
				src: url('./fonts/Montserrat-Bold.woff2') format('woff2');
				font-weight: 700;
				font-style: normal;
			}
			:root{
				--accent1: #3583c7;
				--accent2: #236dad;
				--accent3: #1b5054;
				--accent4: #26686d;
				--error: #ca2b24;
				--white: #fff;
				--black: #000;
				--primary: #1b3e54;
				
				
				--primary1: #424f60;
				--secondary: #7c8a93;
				--secondary1: #b2bdc7;
				--secondary2: #dde2e6;
				--secondary3: #f6f9fb;

				--font-family: 'Montserrat', sans-serif;
				--body-bg: #f6f9fb;
				--promo-title: #fff;

				--btn-primary-text:  #fff;
				--btn-primary:#3583c7;
				
				--btn-primary-hover: #236dad;

				--btn-dark: #1b3e54;
				
				--btn-dark-text:  #fff;
				--btn-dark-hover: #236dad;

				--white-bg: #fff;
				--title-white:#fff;

				--header-text-color: #424f60;
			}
			.hero-bg{
					-webkit-background-image: -webkit-image-set(url('./img/hero.webp') 1x, url('./img/hero@2x.webp') 2x);
				background-image: image-set(url('./img/hero.webp') 1x, url('./img/hero@2x.webp') 2x);
			}
			@media(max-width: 767px){
				.hero-bg{
						-webkit-background-image: -webkit-image-set(url('./img/hero-w375.webp') 1x, url('./img/hero-w375@2x.webp') 2x);
					background-image: image-set(url('./img/hero-w375.webp') 1x, url('./img/hero-w375@2x.webp') 2x);
				}
			}
		//========= swiper slide ========
		link(rel="stylesheet"  href="./libs/swiper/swiper.min.css")
		//========= fancybox ========
		link(rel="stylesheet"  href="./libs/fancybox/fancybox.css")
		
		//========= custom styles ========
		link(rel="stylesheet"  href="./css/main.css")
	
	body(class=(bodyCl !=="" ? bodyCl : ''))
		

		
		block content

		
		//popUp SEARCH
		include ../sections/_search-popup
		//popUp FORM
		include ../sections/_form-popup
		//Swiper
		script(src="./libs/swiper/swiper.js")
		//fancybox
		script(src="./libs/fancybox/fancybox.umd.js")
		script(src="./js/main.js")
	
	