//TEAM
section.our-team
	.container.gap-40
		.our-team-content
			.our-team-info
				h2.h2 Наша команда
				.our-team-text.medi-16
					p Наша компания существует с 2015 года, занимается строительством, асфальтированием и благоустройством. За эти годы хорошо себя зарекомендовала, построив множество городских и промышленных объектов. Клиентам гарантируется высокое качество исполнения, соблюдение всех условий договора. Мы будем рады различным формам сотрудничества с предприятиями и организациями региона, физическими и юридическими лицами. Оформляются все необходимые документы, разрешения контролирующих организаций.
				a(href="#!").btn-primary
					span Подробнее
					svg.svg-right
						use(href='./img/sprite.svg#svg-right')
			.our-team-media
				h2.h2.visible-mobile Наша команда
				.image-back
					picture
						source(srcset="./img/about-w375.webp 1x, ./img/about-w375@2x.webp 2x"  media="(max-width: 767px)")
						img.bor-radius(src='./img/about.webp', srcset='./img/about@2x.webp 2x' width='606' height='398' loading='lazy' alt='img')
				
				a( href="https://www.youtube.com/watch?v=PUdyuKaGQd4"   data-fancybox="team-video"  data-width="100%"   data-height="100%").image-front.has-video
					img.bor-radius(src='./img/about2.webp', srcset='./img/about2@2x.webp 2x' width='352' height='239' loading='lazy' alt='img')
					span.btn-play
				

