//single service content
section.single-service
	.container
		ul.breadcrumbs
			li.breadcrumb-item
				a(href="") Главная
			li.breadcrumb-item
				a(href="") Благоустройство
			li.breadcrumb-item
				a(href="") Услуги по благоустройству
			li.breadcrumb-item
				span Асфальтирование
		
		.sidebar-grid
			//SIDEBAR
			.sidebar-column
				//MENU
				ul.menu-submenu.js-drop.sidebar-menu(data-mode='single')
					li.submenu-item.js-drop-item.js-drop-item-active
						span.submenu-link.js-drop-button Услуги по благоустройству
							svg.svg-carret-down
								use(href='./img/sprite.svg#svg-carret-down')
						.js-drop-body
							ul.menu-sub-submenu.js-drop-content
								li.sub-submenu-item
									a(href='#!') Асвальтирование
								li.sub-submenu-item
									a(href='#!') Укладка тротуарной плитки
								li.sub-submenu-item
									a(href='#!') Озеленение
					li.submenu-item.js-drop-item
						span.submenu-link.js-drop-button Аренда спецтехники
							svg.svg-carret-down
								use(href='./img/sprite.svg#svg-carret-down')
						.js-drop-body
							ul.menu-sub-submenu.js-drop-content
								li.sub-submenu-item
									a(href='#!') Асвальтирование
								li.sub-submenu-item
									a(href='#!') Укладка тротуарной плитки
								li.sub-submenu-item
									a(href='#!') Озеленение
					
					li.submenu-item.js-drop-item
						span.submenu-link.js-drop-button Бетонные полы
							svg.svg-carret-down
								use(href='./img/sprite.svg#svg-carret-down')
