							ul.menu-sub-submenu.js-drop-content
								li.sub-submenu-item
									a(href='#!') Асвальтирование
								li.sub-submenu-item
									a(href='#!') Укладка тротуарной плитки
								li.sub-submenu-item
									a(href='#!') Озеленение
					
				//FORM
				.form-wrapper.form-wrapper-transparent
					.bold-16 Консультация по телефону
					form.feedback-form
						.form-item
							input.form-inp(type="text" placeholder="Имя" required)
						.form-item
							input.form-inp(type="text" placeholder="Телефон" required)
						label.form-agree
							.custom-label
								input(type="checkbox" name="agree_input")
								span.fake-checkbox
							
							span.medi-14 Согласен (на) на #[a.link-underline(href="#") обработку персональных данных]
						button.btn-primary.w-100(type="button")
							span Жду звонка
							svg.svg-round-check
								use(href='./img/sprite.svg#svg-round-check')
			//RIGHT CONTENT
			.content-column
